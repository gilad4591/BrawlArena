{
  "appId": "com.gilad4591.brawlarena",
  "appName": "Brawl Arena",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0b0e1a"
  },
  "ios": {
    "backgroundColor": "#0b0e1a"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 1200,
      "backgroundColor": "#0b0e1a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0b0e1a"
    }
  }
}
