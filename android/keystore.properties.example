# Copy this file to android/keystore.properties (git-ignored) and fill in the
# real values after you create your upload keystore. Do NOT commit the real one.
#
# Create the keystore once (keep the .jks + passwords safe forever — you need
# them for every future update):
#   keytool -genkey -v -keystore brawl-upload.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias brawl-upload
#
# storeFile is relative to the android/app folder (or use an absolute path).
storeFile=../../brawl-upload.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=brawl-upload
keyPassword=YOUR_KEY_PASSWORD
